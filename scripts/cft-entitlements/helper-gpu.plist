<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for "Google Chrome for Testing Helper (GPU).app".
  Mirrors Chromium's chrome/app/helper-gpu-entitlements.plist — the GPU
  process needs unsigned-executable-memory + disable-library-validation
  for SwiftShader/Vulkan ICDs that ship as bundled dylibs.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
