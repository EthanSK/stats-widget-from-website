<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the outer "Google Chrome for Testing.app" bundle.
  Mirrors Chromium's chrome/app/app-entitlements.plist — the browser
  process needs to load arbitrary nested dylibs/helpers under Hardened
  Runtime, and may use Apple Events for AppleScript integration. We
  intentionally do NOT enable sandboxing here; the outer macos-widgets
  app launches CFT as a child process and CFT manages its own
  per-process sandboxing.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
