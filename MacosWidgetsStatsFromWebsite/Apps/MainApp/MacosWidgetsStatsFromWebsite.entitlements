<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is disabled in Release.
	     Reason: the app spawns a bundled Chromium child for CDP scraping +
	     identify flows. Under App Sandbox the spawned Chromium inherits the
	     parent's narrow sandbox profile, hits SIGABRT in its main thread
	     during early init (codeSigningMonitor:2, abort() in Chromium Framework,
	     no usable Chrome console output), and never binds its CDP port —
	     observed deterministically in v0.14.x even with Hardened Runtime
	     entitlements (allow-jit + disable-library-validation + allow-unsigned-
	     executable-memory) set on BOTH the outer .app and the nested
	     Chromium.app. The known cure is to not sandbox the outer app; this
	     forfeits Mac App Store eligibility, which is already deferred per
	     docs/app-store.md. Hardened Runtime remains on for notarization. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>T34G959ZG8.group.com.ethansk.macos-widgets-stats-from-website</string>
	</array>
	<!-- keychain-access-groups MUST use the literal team identifier prefix
	     (T34G959ZG8.) instead of $(AppIdentifierPrefix). Xcode only
	     substitutes $(AppIdentifierPrefix) when a valid provisioning
	     profile resolves the team. Under Debug builds without an active
	     embedded.provisionprofile (common with CODE_SIGN_STYLE=Automatic
	     + transient Apple Development cert), the substitution silently
	     fails and the embedded entitlements end up containing the raw
	     literal "$(AppIdentifierPrefix)..." string. That malforms the
	     keychain-access-groups entry, the trust evaluator rejects the
	     binary's entitlements at exec time, and RunningBoard refuses to
	     launch the process with the generic "RunningBoard has returned
	     error 5" diagnostic. Hard-coding the team prefix sidesteps the
	     provisioning-profile dependency entirely. -->
	<key>keychain-access-groups</key>
	<array>
		<string>T34G959ZG8.com.ethansk.macos-widgets-stats-from-website</string>
	</array>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Hardened Runtime exceptions required to spawn the bundled Chromium child.
	     Chromium's V8 needs JIT-able pages (allow-jit + allow-unsigned-executable-memory),
	     and its frameworks are signed by Google's team identity so dyld must skip
	     library validation when our sandboxed parent process loads them.
	     Without these three, the spawned Chromium quits immediately and CDP never binds.
	     See scripts/embed-chromium.sh for the corresponding nested-bundle entitlements. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
