<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  DEBUG-only entitlements.

	  Why this file exists:
	    Sandboxed Debug builds re-trigger the macOS Sonoma+
	    "MacosStatsWidget would like to access data from other apps"
	    prompt (kTCCServiceSystemPolicyAppData) on every rebuild,
	    because TCC's grant for that service is fragile across the
	    re-signed/re-pathed binary that Xcode produces each build.

	  Solution: app-sandbox=false ONLY in Debug. Release builds keep
	  the full sandbox via MacosWidgetsStatsFromWebsite.entitlements.
	  This file is wired to the Debug configuration via project.yml's
	  configs.Debug override on the main app target.

	  All other entitlements mirror the Release file so dev/prod
	  behavior is otherwise identical (App Group, keychain, network).
	-->
	<!-- Debug entitlements match Release: app-sandbox is OFF because the
	     app spawns bundled Chromium, which SIGABRTs under any sandbox
	     profile (parent's sandbox inherits to child). See the matching
	     Release entitlements file for the full investigation. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>T34G959ZG8.group.com.ethansk.macos-widgets-stats-from-website</string>
	</array>
	<!-- See Release entitlements file for rationale: $(AppIdentifierPrefix)
	     silently fails to substitute in Debug builds without a resolved
	     provisioning profile, malforming this entry and triggering
	     RunningBoard error 5 on Xcode build & run. Use the literal team
	     prefix to sidestep the provisioning-profile dependency. -->
	<key>keychain-access-groups</key>
	<array>
		<string>T34G959ZG8.com.ethansk.macos-widgets-stats-from-website</string>
	</array>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Hardened Runtime exceptions required to spawn the bundled Chromium child.
	     Mirror of the Release entitlements file. See that file for the rationale. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
